# Frontend V2 backend API base URL used in local development.
# Production builds must inject explicit values instead of relying on localhost fallback.
VITE_API_BASE_URL=http://localhost:8000

# Frontend V2 local-detector sidecar base URL used in local development.
# Production builds must inject explicit values instead of relying on localhost fallback.
VITE_LOCAL_DETECTOR_BASE_URL=http://localhost:8091
