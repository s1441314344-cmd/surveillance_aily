APP_NAME=Surveillance V2 API
API_V1_PREFIX=/api
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/surveillance_v2
REDIS_URL=redis://localhost:6379/0
PROVIDER_MOCK_FALLBACK_ENABLED=true
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176,http://localhost:5177,http://127.0.0.1:5177,http://localhost:5178,http://127.0.0.1:5178
STORAGE_ROOT=./data/storage
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123456
BOOTSTRAP_ADMIN_DISPLAY_NAME=开发管理员
