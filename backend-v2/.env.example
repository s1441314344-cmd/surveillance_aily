APP_NAME=Surveillance V2 API
API_V1_PREFIX=/api
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/surveillance_v2
REDIS_URL=redis://localhost:6379/0
SCHEDULER_POLL_INTERVAL_SECONDS=30
SCHEDULER_CAMERA_STATUS_SWEEP_ENABLED=true
SCHEDULER_CAMERA_STATUS_SWEEP_INTERVAL_SECONDS=60
FEEDBACK_TRAINING_ENABLED=true
FEEDBACK_TRAINING_CRON=0 2 * * *
FEEDBACK_TRAINING_MIN_SAMPLES=30
FEEDBACK_TRAINING_POSITIVE_RATIO=1.0
FEEDBACK_TRAINING_MAX_SAMPLES_PER_STRATEGY=2000
FEEDBACK_TRAINING_ROUTE_DEFAULT=finetune
LOCAL_DETECTOR_ENABLED=true
LOCAL_DETECTOR_BASE_URL=http://localhost:8091
LOCAL_DETECTOR_TIMEOUT_SECONDS=5
LOCAL_DETECTOR_PERSON_THRESHOLD=0.35
LOCAL_DETECTOR_STRICT_BLOCK=true
ALERT_LARK_NOTIFY_ENABLED=false
ALERT_LARK_CLI_BIN=lark-cli
ALERT_LARK_CLI_TIMEOUT_SECONDS=15
PROVIDER_MOCK_FALLBACK_ENABLED=true
# Optional: bootstrap provider API keys (stored encrypted on first startup if provider key is empty)
ZHIPU_API_KEY=
OPENAI_API_KEY=
ARK_API_KEY=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176,http://localhost:5177,http://127.0.0.1:5177,http://localhost:5178,http://127.0.0.1:5178,http://localhost:5179,http://127.0.0.1:5179,http://localhost:5180,http://127.0.0.1:5180
STORAGE_ROOT=./data/storage
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123456
BOOTSTRAP_ADMIN_DISPLAY_NAME=开发管理员
